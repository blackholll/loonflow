msgstr "优化：尚无可用工序流时增加创建引导"

#: ../../source/others/release_notes/r3.x/r3.0.1+.rst:21
msgid "Bugfix: Number field maxvalue and minvalue validation"
msgstr "修复：数字字段最大值与最小值校验"

#: ../../source/others/release_notes/r3.x/r3.0.1+.rst:22
msgid "Bugfix: fix attchment field i18 issue"
msgstr "修复：附件字段国际化问题"

#: ../../source/others/release_notes/r3.x/r3.0.1+.rst:28
