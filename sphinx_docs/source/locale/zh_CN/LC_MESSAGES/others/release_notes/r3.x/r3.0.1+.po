msgid "Feature: add MCP ticket server"
msgstr "功能：新增 MCP 工单服务"

#: ../../source/others/release_notes/r3.x/r3.0.1+.rst:18
msgid "Feature: add about Information on Frontend page"
msgstr "功能：前端增加「关于」信息页"

#: ../../source/others/release_notes/r3.x/r3.0.1+.rst:19
msgid ""
"Optimize: user info display optimization(ticket list and ticket history "
"record)"
msgstr "优化：用户信息展示（工单列表与工单流转记录）"

#: ../../source/others/release_notes/r3.x/r3.0.1+.rst:20
msgid ""
"Optimize: added user guidance for creating workflows when none are "
